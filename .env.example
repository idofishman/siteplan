# Supabase project URL — find in Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Supabase anon key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role key — bypasses RLS. NEVER expose to the client.
# Use only in server-side API routes for admin operations.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Secret for protecting the presence cleanup cron endpoint.
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-secret-here
